# Production environment variables for Vercel deployment
# Copy these into the Vercel dashboard (Project Settings → Environment Variables)
VITE_APP_NAME=FrostyFlow
VITE_APP_VERSION=0.1.0
VITE_NETWORK=mainnet
VITE_RPC_ENDPOINT=https://your-rpc-endpoint.example
VITE_API_BASE_URL=https://your-backend.example
VITE_ENABLE_MOCK=false
VITE_SUBSCAN_API_KEY=
